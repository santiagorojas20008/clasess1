import math

class Circulo:
    def __init__(self, radio):
        self.radio = radio
        # El diametro siempre es el doble del radio
        self.diametro = radio * 2

    def calcular_area(self):
        """Calcula el área: π * radio²"""
        area = math.pi * (self.radio ** 2)
        return area

    def calcular_circunferencia(self):
        """Calcula el perímetro (circunferencia): 2 * π * radio"""
        circunferencia = 2 * math.pi * self.radio
        return circunferencia


mi_circulo = Circulo(5)

print(f"Radio: {mi_circulo.radio}")
print(f"Diámetro: {mi_circulo.diametro}")
print(f"Área: {mi_circulo.calcular_area():.2f}") 
print(f"Circunferencia: {mi_circulo.calcular_circunferencia():.2f}")
